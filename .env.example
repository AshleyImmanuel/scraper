# =============================================================================
# YT LeadMiner — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# All settings have sensible defaults except API keys which are REQUIRED.
# =============================================================================

# ---- Required API Keys ----
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
SCRAPER_API_KEY=your_scraperapi_key_here

# ---- App Settings ----
# APP_HOST=0.0.0.0
# APP_PORT=8001
# UVICORN_RELOAD=False
# ENABLE_API_DOCS=False

# ---- YouTube Content Filters ----
# Comma-separated keywords to exclude from results (case-insensitive)
# YOUTUBE_EXCLUSION_KEYWORDS=montage,edit,amv,gmv,phonk,tribute,...
# YOUTUBE_STRICT_EXCLUSIONS=hindi,urdu,telugu,tamil,dub,sub,aur

# ---- Email Extraction ----
# Emails to ignore during scraping (comma-separated)
# SCRAPER_EMAIL_BLACKLIST=noreply@youtube.com,support@google.com,...

# ---- Output ----
# Columns to include in the Excel report (comma-separated)
# EXCEL_OUTPUT_COLUMNS=title,id,viewCount,likes,duration,date,channelName,url,channelUrl,numberOfSubscribers,EMAIL,Country

# ---- Concurrency & Limits ----
# SCRAPER_CONCURRENCY=3
# MAX_CONCURRENT_JOBS=2

# ---- Timeouts (milliseconds) ----
# SCRAPER_ABOUT_TIMEOUT_MS=60000
# SCRAPER_CHANNEL_TIMEOUT_MS=60000
# SCRAPER_EXTERNAL_TIMEOUT_MS=20000

# ---- Web Crawler Settings ----
# CRAWLER_ENABLED=true
# CRAWLER_DELAY_MS=1000
# CRAWLER_MAX_PAGES=50

# ---- Local Browser (Playwright) ----
# USE_LOCAL_BROWSER=True
# BROWSER_HEADLESS=True
# BROWSER_ZOOM=0.8
# ENABLE_ADVANCED_STEALTH=True
# BROWSER_PROXY_SESSION=mattscrape_persist

# ---- Google Dork Discovery ----
# GOOGLE_DISCOVERY_ENABLED=false
# GOOGLE_DISCOVERY_MAX_PAGES=3
