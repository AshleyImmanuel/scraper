# YouTube Data API v3 key
YOUTUBE_API_KEY=AIzaSyA_7Y03AJqiSXTsxhPi9-j8zf-rfBDdeBc

# ScraperAPI key (used as proxy for Playwright)
SCRAPER_API_KEY=783e0b2762adc9c0bbe12a9f8fed38ca

# Development settings
UVICORN_RELOAD=False

# Filtering keywords (comma-separated, case-insensitive)
YOUTUBE_EXCLUSION_KEYWORDS=montage,edit,amv,gmv,phonk,tribute,status,alight motion,capcut,velocity,lyrics,ffx,gaming,gameplay,playthrough,walkthrough,music video,official video,song,mv,remix,mix,ncs,non-copyright,audio,vocal,instrumental,ai,stable diffusion,midjourney,dalle,tutorial,how to,course,lesson,aesthetic,vibe,mood,slowed,reverb,lofi,nightcore,relaxing,bass boosted,animeedit,amvs,gmvs,tiktok,reels,shorts,compilation,reaction,instagram,socks,feet,cosplay

# Emails to ignore during scraping (comma-separated)
SCRAPER_EMAIL_BLACKLIST=noreply@youtube.com,support@google.com,press@youtube.com,example@example.com,name@example.com,email@example.com,copyright@youtube.com,legal@google.com,abuse@youtube.com

# Columns to include in the Excel report (comma-separated)
EXCEL_OUTPUT_COLUMNS=title,id,viewCount,likes,duration,date,channelName,url,channelUrl,numberOfSubscribers,EMAIL,Country
ENABLE_API_DOCS=True
# Concurrency Settings
SCRAPER_CONCURRENCY=1
MAX_CONCURRENT_JOBS=2

# Timeouts
SCRAPER_ABOUT_TIMEOUT_MS=60000
SCRAPER_CHANNEL_TIMEOUT_MS=60000
SCRAPER_EXTERNAL_TIMEOUT_MS=20000

# Google Dork Discovery (uses ScraperAPI credits to search Google for channels mentioning emails)
# Set to true to enable supplemental Google-based channel discovery
GOOGLE_DISCOVERY_ENABLED=true
GOOGLE_DISCOVERY_MAX_PAGES=3

# Web Crawler Settings (Apify-style page crawling instead of API search)
CRAWLER_ENABLED=true
CRAWLER_DELAY_MS=1000
CRAWLER_MAX_PAGES=20
USE_LOCAL_BROWSER=True
BROWSER_HEADLESS=True
ENABLE_ADVANCED_STEALTH=True

# Persistent Sign-in: Fixed proxy session ID keeps the same IP across restarts
# so Google doesn't invalidate your login cookies
BROWSER_PROXY_SESSION=mattscrape_persist

